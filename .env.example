# EcoMetrics Environment Configuration
# Copy this file to .env and populate with real values

# =====================================
# Server
# =====================================
PORT=3000
NODE_ENV=development

# =====================================
# Session Security
# Must be a random 64-character string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =====================================
SESSION_SECRET=replace_with_a_random_64_character_secret_string_for_production

# =====================================
# Google OAuth 2.0 (for Calendar Integration)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# =====================================
OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# =====================================
# Gemini AI API Key
# Get your key at: https://aistudio.google.com/app/apikey
# =====================================
GEMINI_API_KEY=your_gemini_api_key_here
